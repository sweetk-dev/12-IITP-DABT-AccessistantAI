# .env.example
# 실제 사용 시 .env 로 복사 후 본인 값으로 채우세요.
# 보안 원칙: 비밀 키·연결 정보는 외부 유출 금지. .env 는 반드시 .gitignore 에 포함.

# PostgreSQL
DB_NAME=welfare_db
DB_USER=postgres
DB_PASS=여기에_DB_비밀번호_입력
DB_HOST=127.0.0.1
DB_PORT=5432

# Gemini API (도구 #2, #5 의 벡터 임베딩 호출용)
GEMINI_API_KEY=여기에_Gemini_API_키_입력

# ── LLM 백엔드 선택 (정책 갱신 엔진) ──────────────────────────────
# 정기 크롤러가 정책 변경을 감지하면 갱신 JSON(필드 패치)을 생성하는 LLM 백엔드.
#   gemini  — Google Gemini API (GEMINI_API_KEY 재사용 — 벤더 단일화, 권장 기본값)
#   claude  — Anthropic Claude API (ANTHROPIC_API_KEY 필요)
#   gemma   — 온프레미스 Gemma (GEMMA_API_URL 등, 향후)
LLM_BACKEND=gemini

# gemini 백엔드 모델 (LLM_BACKEND=gemini 일 때 사용)
GEMINI_LLM_MODEL=gemini-3.1-pro-preview

# claude 백엔드 사용 시에만 필요 (LLM_BACKEND=claude)
# ANTHROPIC_API_KEY=여기에_Claude_API_키_입력
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Gemini Live API 모델명 (Phase 3 WebSocket 브릿지용)
# 권장 후보 (호환성 안 되면 다음으로 시도):
#   1) gemini-2.0-flash-live-001          (안정 GA, 기본값)
#   2) gemini-live-2.5-flash-preview      (최신 preview)
#   3) gemini-2.5-flash-preview-native-audio-dialog  (네이티브 오디오 대화)
#   4) gemini-3.1-flash-live-preview      (사용자 이전 검증)
GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001

# 크롤러 User-Agent contact (운영자 이메일/연락처 — 외부 사이트 차단 시 식별용)
CRAWLER_CONTACT=contact@example.com

# (선택) 정책 가변 데이터 경로 — 배포 시 영속 볼륨 분리용.
# 미설정 시 코드 디렉터리(policy_db) 기본값 사용. 설정 시 items/staging/snapshots/reports/manual_review_state 가 이 경로 하위에서 해석됨.
# POLICY_DATA_DIR=/data
