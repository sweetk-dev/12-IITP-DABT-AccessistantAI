# .env.example
# 실제 사용 시 .env 로 복사 후 본인 값으로 채우세요.
# 보안 원칙: 비밀 키·연결 정보는 외부 유출 금지. .env 는 반드시 .gitignore 에 포함.

# PostgreSQL
DB_NAME=welfare_db
DB_USER=postgres
DB_PASS=여기에_DB_비밀번호_입력
DB_HOST=127.0.0.1
DB_PORT=5432

# Gemini API (도구 #2, #5 의 벡터 임베딩 호출용)
GEMINI_API_KEY=여기에_Gemini_API_키_입력

# ── LLM 백엔드 선택 (정책 갱신 엔진) ──────────────────────────────
# 정기 크롤러가 정책 변경을 감지하면 갱신 JSON(필드 패치)을 생성하는 LLM 백엔드.
#   gemini  — Google Gemini API (GEMINI_API_KEY 재사용 — 벤더 단일화, 권장 기본값)
#   gemma   — 온프레미스 Gemma (GEMMA_API_URL 등, 향후)
LLM_BACKEND=gemini

# gemini 백엔드 모델 (LLM_BACKEND=gemini 일 때 사용)
GEMINI_LLM_MODEL=gemini-3.1-pro-preview

# ── (발굴/보강) 호출 항목별 모델 분리 — 비용 최적화. 미설정 시 위 GEMINI_LLM_MODEL 사용 ──
# 분류(classify)는 가볍고 빠른 저가 모델 권장 / 신규초안·재보강·보강(draft/enrich/gap)은 품질 모델.
# GEMINI_MODEL_CLASSIFY=gemini-2.5-flash
# GEMINI_MODEL_DRAFT=gemini-3.1-pro-preview
# GEMINI_MODEL_ENRICH=gemini-3.1-pro-preview
# GEMINI_MODEL_GAP=gemini-3.1-pro-preview

# ── 차선책(fallback) 가드 — Gemini 실패(429 한도 초과/장애/타임아웃) 시 온프레미스 Gemma 폴백 ──
# 비용 소진·장애 시에도 발굴/보강이 끊기지 않도록. grounding(웹검색)은 폴백에서 불가 → 모델 지식 기반(검토 필수).
# LLM_FALLBACK=gemma            # 미설정=비활성(기존 동작)
# GEMMA_API_URL=http://ollama:11434   # compose 내부 ollama 서비스
# GEMMA_MODEL=gemma4
# GEMMA_API_STYLE=ollama        # 또는 openai (vLLM 등)
# GEMMA_API_KEY=


# Gemini Live API 모델명 (Phase 3 WebSocket 브릿지용)
#   ⚠️ gemini-2.0-flash-live-001 은 2025-12-09 서비스 종료(사용 불가).
#   현행 권장: gemini-3.1-flash-live-preview
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# ── Gemini Live 음성 폴백 (온프레미스 STT + Gemma + TTS) ──────────
# Live 연결이 결제 크레딧 소진·권한 등 "재연결 불가" 사유로 실패하면,
# 동일한 클라이언트 프로토콜을 유지한 채 로컬 음성 상담으로 조용히(silent) 전환.
# (이용자에게는 결제/전환 사실을 노출하지 않음)
LIVE_LOCAL_FALLBACK=1
LOCAL_LLM_MODEL=gemma4:26b        # 미설정 시 GEMMA_MODEL 사용 (ollama)
LOCAL_STT_MODEL=medium            # faster-whisper 한국어 (small=빠름 / medium=정확)
LOCAL_STT_DEVICE=cpu              # GPU는 gemma4:26b 상주로 여유 없음 → CPU
LOCAL_STT_COMPUTE=int8
LOCAL_TTS_ENGINE=melo             # melo | piper
# LOCAL_TTS_PIPER_MODEL=/models/piper/ko_KR.onnx
LOCAL_VAD_SILENCE_MS=1200

# 크롤러 User-Agent contact (운영자 이메일/연락처 — 외부 사이트 차단 시 식별용)
CRAWLER_CONTACT=contact@example.com

# (선택) 정책 가변 데이터 경로 — 배포 시 영속 볼륨 분리용.
# 미설정 시 코드 디렉터리(policy_db) 기본값 사용. 설정 시 items/staging/snapshots/reports/manual_review_state 가 이 경로 하위에서 해석됨.
# POLICY_DATA_DIR=/data
